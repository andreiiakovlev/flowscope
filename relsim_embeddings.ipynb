   "source": [
    "import torch\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "from PIL import Image\n",
    "\n",
    "from relsim.relsim_score import relsim\n",
    "\n",
    "# ---- config ----\n",
    "CHECKPOINT_DIR = #  your local path\n",
    "\n",
    "\n",
    "# ---- load model ----\n",
    "model, preprocess = relsim(pretrained=True, checkpoint_dir=CHECKPOINT_DIR)\n",
    "model.eval()\n",
    "\n",
    "#model.model = model.model.to(\"cuda:0\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "38a74b85-0429-47c5-b6e3-8a51550cb96a",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "['images/10607551224_post_0.jpg',\n",
       " 'images/10607551224_post_1.jpg',\n",
       " 'images/10607551224_post_10.jpg',\n",
       " 'images/10607551224_post_11.jpg']"
      ]
     },
     "execution_count": 3,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "import os\n",
    "\n",
    "image_files = sorted([\"images/\"+_ for _ in os.listdir(\"images/\") if \".jpg\" in _])\n",
    "image_files[:4]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "2f98dad7-b95e-446c-885e-fd9b02538191",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "100%|██████████| 563/563 [03:31<00:00,  2.66it/s]\n"
     ]
    }
   ],
   "source": [
    "#!pip install relsim\n",
    "from tqdm import tqdm\n",
    "\n",
    "emb_dict = dict()\n",
    "\n",
    "for idx in tqdm(range(len(image_files))):\n",
    "    IMAGE_PATH = image_files[idx]\n",
    "    # ---- embed one image -> numpy ----\n",
    "    img_pil = Image.open(IMAGE_PATH).convert(\"RGB\")\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        # depending on relsim API, embed() may accept PIL directly\n",
    "        emb = model.embed(img_pil)                 # shape: (1, D) or (D,)\n",
    "        emb = F.normalize(emb, dim=-1)             # optional, but usually desired\n",
    "        emb_np = emb.detach().cpu().float().numpy()\n",
    "    \n",
    "    # if it's (1, D), squeeze to (D,)\n",
    "    emb_np = np.squeeze(emb_np)\n",
    "\n",
    "    emb_dict[IMAGE_PATH] = emb_np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "8d34d097-8eed-4fc4-b7e3-6dace5e004ca",
   "metadata": {},
   "outputs": [],
   "source": [
    "for key in emb_dict:\n",
    "    emb_dict[key] = [float(_) for _ in emb_dict[key]]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "d1b3c9dc-604e-4b39-8b1b-4ab1794fb31d",
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "\n",
    "with open(\"post_images_embeddings.json\", \"w\") as f:\n",
    "    json.dump(emb_dict, f)"
   ]
  },
